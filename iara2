<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Quiz - Lenda da Iara</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(#4facfe, #00f2fe);
      color: #fff;
      text-align: center;
      padding: 20px;
    }
    .container {
      background: rgba(0,0,0,0.6);
      padding: 20px;
      border-radius: 15px;
      max-width: 500px;
      margin: auto;
    }
    button {
      display: block;
      width: 100%;
      margin: 10px 0;
      padding: 10px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      background: #00c3ff;
      color: white;
      font-size: 16px;
    }
    button:hover {
      background: #0099cc;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Quiz da Lenda da Iara</h1>
    <p id="pergunta"></p>
    <div id="respostas"></div>
    <p id="resultado"></p>
  </div>

  <script>
    const perguntas = [
      {
        pergunta: "Quem é Iara na lenda brasileira?",
        respostas: ["Uma sereia", "Uma guerreira", "Uma deusa do fogo"],
        correta: 0
      },
      {
        pergunta: "Onde Iara vive?",
        respostas: ["Na floresta", "Nos rios", "No deserto"],
        correta: 1
      },
      {
        pergunta: "O que Iara faz com os homens?",
        respostas: ["Ajuda eles", "Encanta e leva para o fundo do rio", "Ignora"],
        correta: 1
      }
    ];

    let atual = 0;
    let pontuacao = 0;

    function carregarPergunta() {
      const p = perguntas[atual];
      document.getElementById("pergunta").innerText = p.pergunta;
      const respostasDiv = document.getElementById("respostas");
      respostasDiv.innerHTML = "";

      p.respostas.forEach((resposta, index) => {
        const btn = document.createElement("button");
        btn.innerText = resposta;
        btn.onclick = () => verificarResposta(index);
        respostasDiv.appendChild(btn);
      });
    }

    function verificarResposta(index) {
      if (index === perguntas[atual].correta) {
        pontuacao++;
      }
      atual++;
      if (atual < perguntas.length) {
        carregarPergunta();
      } else {
        mostrarResultado();
      }
    }

    function mostrarResultado() {
      document.querySelector(".container").innerHTML = `<h1>Resultado</h1><p>Você acertou ${pontuacao} de ${perguntas.length} perguntas!</p>`;
    }

    carregarPergunta();
  </script>
</body>
</html>
